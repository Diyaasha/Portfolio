# Environment Variables Template
# Copy this file to .env and fill in your actual values
# Never commit .env to git - it's already in .gitignore

# Email Service (if using EmailJS, Formspree, etc.)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_public_key

# Contact Form Service (if using Formspree)
# FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Analytics (if using Google Analytics, etc.)
# GA_TRACKING_ID=G-XXXXXXXXXX

# API Keys (if adding any APIs later)
# API_KEY=your_api_key_here
# API_URL=https://api.example.com

# Note: This is a static HTML/CSS/JS portfolio
# Environment variables are only needed if you add:
# - Contact form with email service
# - Analytics tracking
# - External API integrations
# - Backend services
